# MagicFit AI Outreach Bot - Environment Variables
# Copy this to .env and fill in your values

# REQUIRED: Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_new_telegram_bot_token_here

# REQUIRED: Your Telegram user ID (get from @userinfobot)
ALLOWED_USER_ID=your_telegram_user_id_here

# OPTIONAL: AI API keys (bot works if at least one is provided)
# Gemini is primary (best quality, free, vision + text)
GEMINI_API_KEY=

# Mistral is vision fallback 1, used after Gemini for screenshot OCR (Pixtral Large, free, no card)
MISTRAL_API_KEY=

# Groq is text fallback 1 (fast, free)
GROQ_API_KEY=

# NVIDIA NIM is text + vision fallback 2 (free, no card)
NVIDIA_API_KEY=

# OPTIONAL: Scrapingdog for Instagram scraping
SCRAPINGDOG_API_KEY=
